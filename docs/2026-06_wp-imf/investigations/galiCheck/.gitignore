# Dynare-generated artifacts (regenerated by running the mods) -- keep only the
# source .mod / .m / .png / .md. Patterns are model-name-agnostic.
+*/
# per-model output dirs Dynare creates (named after the .mod)
gali_g/
ours_g/
ours_paper/
# logs, journals, generated drivers
*.log
*.jnl
*_dynamic.m
*_static.m
*_set_auxiliary_variables.m
*_results.mat
*.eps
*.fig
gali_g.m
ours_g.m
ours_paper.m
